# Nexus AI — example environment configuration.
# Copy to `.env` and adjust. NEVER commit your real `.env`.
#   cp .env.example .env
#
# These are read by config.py (the Streamlit/RAG tooling) and mirror the
# defaults baked into boot.sh for the Open WebUI deployment. Everything has a
# sensible default, so an empty .env still runs against a local tunnel.

# --- Services (when tunnelled from the GPU box to localhost) ----------------
OLLAMA_HOST=http://localhost:11434
CHROMA_HOST=localhost
CHROMA_PORT=8000
COLLECTION_NAME=instrument_failures

# --- Model suite (Qwen3.5 / 3.6) --------------------------------------------
# Fast/daily chat. Deep analysis -> 122B. Coding -> 27B. Vision/P&ID -> VL 32B.
FAST_MODEL=qwen3.5:35b
REASONING_MODEL=qwen3.5:122b
CODE_MODEL=qwen3.6:27b
VISION_MODEL=qwen3-vl:32b
EMBED_MODEL=qwen3-embedding:4b

# How long Ollama keeps a model resident in VRAM after use.
# -1 = forever (needs enough VRAM to hold every hot model); or "10m", "30m".
OLLAMA_KEEP_ALIVE=-1

# --- Access control (optional) ----------------------------------------------
# If set, the Streamlit app shows a password gate. Leave empty for local dev.
# (Open WebUI has its own auth via WEBUI_AUTH — set a strong admin password
# at first-run signup instead.)
APP_PASSWORD=

# --- System prompt (optional override) --------------------------------------
# CHAT_SYSTEM_PROMPT="You are a knowledgeable assistant for an OT cybersecurity consultancy..."
